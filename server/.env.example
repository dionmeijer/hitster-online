# Spotify API credentials
# Register a free app at https://developer.spotify.com/dashboard
# No scopes or redirect URIs needed — Client Credentials Flow only
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Server port
PORT=3000

# Test / demo mode — set to "true" to skip Spotify entirely.
# The server will use a built-in set of mock tracks so the game
# can be run and tested without real API credentials.
# Never set this in production.
TEST_MODE=false
