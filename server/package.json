{
  "name": "hitster-online-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev":        "tsx watch src/index.ts",
    "dev:test":   "TEST_MODE=true tsx watch src/index.ts",
    "test:server": "tsx src/index.ts",
    "build":      "tsc",
    "start":      "node dist/server/src/index.js",
    "test":       "jest --runInBand",
    "test:watch": "jest --watch",
    "test:ci":    "jest --runInBand --ci --coverage"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.5",
    "tsx": "^4.15.6",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src", "<rootDir>/../shared"],
    "testMatch": ["**/*.test.ts"],
    "moduleNameMapper": {
      "^@shared/(.*)$": "<rootDir>/../shared/$1"
    }
  }
}
