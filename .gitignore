# Dependencies
node_modules/
.pnp
.pnp.js

# Environment variables — never commit these
.env
.env.local
.env.*.local

# Build output
dist/
build/

# TypeScript
*.tsbuildinfo

# Compiled JS emitted next to source (e.g. from failed tsc runs)
shared/**/*.js
shared/**/*.d.ts

# Logs
*.log
npm-debug.log*

# OS
.DS_Store
Thumbs.db

# Editor
.vscode/
.idea/
*.swp
.claude/

# Compiled JS files in source dirs (from tsc --outDir leaks)
client/src/**/*.js
shared/*.js
bots/src/**/*.js
